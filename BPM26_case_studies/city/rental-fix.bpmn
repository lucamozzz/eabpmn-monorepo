  <bpmn:process id="CarFixer" isExecutable="true" camunda:historyTimeToLive="0">
    <bpmn:startEvent id="Event_17dn21k" name="are there any cars to fix?">
      <bpmn:extensionElements>
        <space:guard>Unavailable Cars.count &gt; 0</space:guard>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1fesipt</bpmn:outgoing>
      <bpmn:conditionalEventDefinition id="ConditionalEventDefinition_1smmbjy">
        <bpmn:condition xsi:type="bpmn:tFormalExpression">${true}</bpmn:condition>
      </bpmn:conditionalEventDefinition>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_1mgoc2n">
      <bpmn:incoming>Flow_1fesipt</bpmn:incoming>
      <bpmn:incoming>Flow_1tobsxx</bpmn:incoming>
      <bpmn:outgoing>Flow_0aqqpzd</bpmn:outgoing>
