      <messageEventDefinition id="MessageEventDefinition_02ckqwt" messageRef="Message_1vkf9r4" />
    </intermediateThrowEvent>
    <exclusiveGateway id="Gateway_1ujw22y" name="are there any available bikes?">
      <incoming>Flow_07a84bk</incoming>
      <outgoing>Flow_0qzdu8c</outgoing>
      <outgoing>Flow_16ykrk9</outgoing>
    </exclusiveGateway>
