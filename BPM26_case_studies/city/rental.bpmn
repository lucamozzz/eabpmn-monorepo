    <sequenceFlow id="Flow_07a84bk" sourceRef="Event_13zb12d" targetRef="Gateway_1ujw22y" />
    <sequenceFlow id="Flow_16ykrk9" name="yes" sourceRef="Gateway_1ujw22y" targetRef="Event_1cg44bm">
      <extensionElements>
        <space:guard>Available Bikes.count &gt; 0</space:guard>
      </extensionElements>
      <conditionExpression xsi:type="tFormalExpression">${true == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_0oni4in" sourceRef="Event_1cg44bm" targetRef="Event_0vslly4" />
    <sequenceFlow id="Flow_0qzdu8c" name="no" sourceRef="Gateway_1ujw22y" targetRef="Event_1g38q5z">
      <extensionElements>
        <space:guard>Available Bikes.count == 0</space:guard>
      </extensionElements>
      <conditionExpression xsi:type="tFormalExpression">${true == true}</conditionExpression>
    </sequenceFlow>
    <endEvent id="Event_1wju85z" name="End bike rental">
      <incoming>Flow_15ao5ey</incoming>
